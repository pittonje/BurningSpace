{
  "name": "burningspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "archive:source": "node scripts/create-source-archive.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:client": "npm run dev -w @burningspace/client",
    "dev:server": "npm run dev -w @burningspace/server",
    "build": "npm run build --workspaces",
    "build:client": "npm run build -w @burningspace/client",
    "build:server": "npm run build -w @burningspace/server",
    "check:protocol-profile": "npm run build -w @burningspace/shared && npm run build -w @burningspace/protocol && node packages/protocol/dist/profile-compatibility-check.js",
    "typecheck": "npm run typecheck --workspaces",
    "typecheck:client": "npm run typecheck -w @burningspace/client",
    "typecheck:server": "npm run typecheck -w @burningspace/server"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "3.2.4"
  }
}
